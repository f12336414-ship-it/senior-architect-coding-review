{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/f12336414-ship-it/senior-architect-coding-review/schemas/action-plan.schema.json",
  "title": "Agent action plan",
  "type": "object",
  "required": ["schema_version", "allowed_paths", "actions"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "allowed_paths": {"type": "array", "items": {"type": "string"}},
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "category", "target"],
        "properties": {
          "id": {"type": "string"},
          "category": {"type": "string"},
          "operation": {"type": "string"},
          "target": {"type": "string"},
          "command": {"type": "string"},
          "out_of_scope": {"type": "boolean"},
          "bypasses_tests": {"type": "boolean"},
          "disables_guardrail": {"type": "boolean"},
          "irreversible": {"type": "boolean"},
          "verified_absolute_target": {"type": "boolean"},
          "recovery_plan": {"type": "string"},
          "approval": {
            "type": "object",
            "required": ["status", "role", "timestamp", "evidence"],
            "properties": {
              "status": {"const": "approved"},
              "role": {"type": "string"},
              "timestamp": {"type": "string", "format": "date-time"},
              "evidence": {"type": "string"}
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
