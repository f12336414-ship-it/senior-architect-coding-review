{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/f12336414-ship-it/senior-architect-coding-review/schemas/review-report.schema.json",
  "title": "Architecture and code review report",
  "type": "object",
  "required": ["schema_version", "mode", "permission", "risk_level", "summary", "findings", "verification", "residual_risks"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "mode": {"enum": ["quick", "standard", "high-risk"]},
    "permission": {"enum": ["review-only", "review-and-fix"]},
    "risk_level": {"enum": ["low", "medium", "high", "critical"]},
    "summary": {"type": "string", "minLength": 1},
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "severity", "disposition", "confidence", "locations", "scenario", "impact", "evidence", "minimal_fix"],
        "properties": {
          "id": {"type": "string"},
          "title": {"type": "string"},
          "severity": {"enum": ["P0", "P1", "P2", "P3"]},
          "disposition": {"enum": ["blocking", "advisory"]},
          "confidence": {"enum": ["high", "medium", "low"]},
          "locations": {"type": "array", "items": {"type": "object", "required": ["path", "line"]}},
          "scenario": {"type": "string"},
          "impact": {"type": "string"},
          "evidence": {"type": "array", "items": {"type": "string"}},
          "minimal_fix": {"type": "string"}
        },
        "additionalProperties": true
      }
    },
    "verification": {"type": "array", "items": {"type": "object", "required": ["command", "status"]}},
    "residual_risks": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": false
}
